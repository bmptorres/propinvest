const APP_NAME = 'Bruno Torres - TessaAdvisors';
const ALLOWED_INVITE_LINK_PREFIX = 'https://bmptorres.github.io/propinvest/';
const MAX_SUBJECT_LENGTH = 140;
const MAX_MESSAGE_LENGTH = 4000;
const LOGO_BASE64 = '';
function doGet(e) {
  const data = getInviteData_(e);
  const error = validateInviteData_(data);
  if (error) {
    return page_('Convite bloqueado', `<p>${escapeHtml_(error)}</p><p>Volta ao PropInvest e gera novamente o convite.</p>`);
  }

  const html = `
    <p class="muted">Confirma o envio do convite abaixo.</p>
    <div class="box">
      
      <div><strong>Para:</strong> ${escapeHtml_(data.to)}</div>
      
      <div><strong>Assunto:</strong> ${escapeHtml_(data.subject)}</div>
      
      <div><strong>Projeto:</strong> ${escapeHtml_(data.project || 'Projeto')}</div>
    </div>
    <label>Mensagem</label>
    <pre>${escapeHtml_(data.message)}</pre>
    <div class="logo-preview"><img src="data:image/png;base64,${LOGO_BASE64}" alt="TESSA Advisors"></div>
    <form method="post" action="${ScriptApp.getService().getUrl()}">
      
      ${hidden_('to', data.to)}
      
      ${hidden_('subject', data.subject)}
      
      ${hidden_('message', data.message)}
      
      ${hidden_('link', data.link)}
      
      ${hidden_('project', data.project)}
      ${hidden_('logo', data.logo)}
      
      <button type="submit">Enviar convite</button>
    </form>
    <p class="small">O email sera enviado pela conta Google que autorizou este Apps Script.</p>
  `;
  return page_('Enviar convite PropInvest', html);
}

function doPost(e) {
  const data = getInviteData_(e);
  const error = validateInviteData_(data);
  if (error) {
    return page_('Convite bloqueado', `<p>${escapeHtml_(error)}</p><p>Volta ao PropInvest e gera novamente o convite.</p>`);
  }

  MailApp.sendEmail({
    to: data.to,
    subject: data.subject,
    body: data.message,
    htmlBody: emailHtml_(data),
    name: APP_NAME,
    replyTo: Session.getActiveUser().getEmail(),
    inlineImages: {tessaLogo: logoBlob_()}
  });

  const quota = MailApp.getRemainingDailyQuota();
  return page_('Convite enviado', `<p>Convite enviado para <strong>${escapeHtml_(data.to)}</strong>.</p><p class="small">Envios restantes hoje: ${quota}</p>`);
}

function getInviteData_(e) {
  const p = (e && e.parameter) || {};
  return {
    to: normalizeEmail_(p.to),
    subject: cleanText_(p.subject, MAX_SUBJECT_LENGTH),
    message: cleanText_(p.message, MAX_MESSAGE_LENGTH),
    link: cleanText_(p.link, 700),
    project: cleanText_(p.project, 160),
    logo: cleanText_(p.logo, 1200)
  };
}

function validateInviteData_(data) {
  if (!data.to || !data.subject || !data.message) return 'Faltam dados obrigatorios no convite.';
  if (!isValidEmail_(data.to)) return 'O email do investidor nao e valido.';
  if (data.subject.length > MAX_SUBJECT_LENGTH) return 'O assunto do convite e demasiado longo.';
  if (data.message.length > MAX_MESSAGE_LENGTH) return 'A mensagem do convite e demasiado longa.';
  if (!data.link || !isAllowedInviteLink_(data.link)) return 'O link do convite nao pertence ao PropInvest autorizado.';
  if (data.message.indexOf(data.link) === -1) return 'A mensagem nao contem o link de convite validado.';
  return '';
}

function normalizeEmail_(value) {
  return String(value || '').trim().toLowerCase();
}

function cleanText_(value, maxLength) {
  return String(value || '').trim().slice(0, maxLength || 1000);
}

function isValidEmail_(value) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(value || '')) && String(value || '').length <= 254;
}

function isAllowedInviteLink_(link) {
  const value = String(link || '');
  return value.indexOf(ALLOWED_INVITE_LINK_PREFIX) === 0
    && /[?&]invite=[^&]+/.test(value)
    && /[?&]project=[^&]+/.test(value);
}

function emailHtml_(data) {
  const lines = escapeHtml_(data.message).split('\n');
  const body = lines.map(line => line ? `<p>${line}</p>` : '<p>&nbsp;</p>').join('');
  const logo = `<div style="margin-top:24px"><img src="cid:tessaLogo" alt="TESSA Advisors" style="width:220px;max-width:80%;height:auto;display:block"></div>`;
  return `<div style="font-family:Arial,sans-serif;color:#111827;font-size:15px;line-height:1.5">${body}${logo}</div>`;
}

function logoBlob_() {
  return Utilities.newBlob(Utilities.base64Decode(LOGO_BASE64), 'image/png', 'tessa-advisors-logo.png');
}

function page_(title, body) {
  const html = `<!doctype html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body{font-family:Arial,sans-serif;margin:0;background:#f6f7f8;color:#111827}
    main{max-width:680px;margin:32px auto;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:24px;box-shadow:0 12px 30px rgba(15,23,42,.08)}
    h1{font-size:22px;margin:0 0 16px}
    .muted,.small{color:#6b7280}.small{font-size:13px}
    .box{background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:14px;margin:14px 0;line-height:1.7}
    label{display:block;font-weight:700;margin:18px 0 8px}
    pre{white-space:pre-wrap;background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:14px;line-height:1.45}
    .logo-preview{margin:18px 0}.logo-preview img{display:block;max-width:320px;width:70%;height:auto}
    button{border:0;border-radius:10px;background:#111827;color:#fff;font-weight:700;padding:12px 16px;cursor:pointer}
  </style>
</head>
<body><main><h1>${escapeHtml_(title)}</h1>${body}</main></body>
</html>`;
  return HtmlService.createHtmlOutput(html).setTitle(title);
}

function hidden_(name, value) {
  return `<input type="hidden" name="${escapeHtml_(name)}" value="${escapeHtml_(value)}">`;
}

function escapeHtml_(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}